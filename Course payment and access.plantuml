@startuml
autonumber
skinparam Style strictuml

actor User
participant "Payment Controller" as PC
participant "Transaction Orchestrator" as TO
participant "Payment Gateway Client" as GC
database "Payment DB" as DB
participant "Enrollment Service" as ES
participant "Secure Logger" as SL

User -> PC : POST /payments (course_id)
note left: FR-5.1: Purchase course [cite: 1]

PC -> TO : processPayment(userId, courseId, details)
activate TO

TO -> DB : createTransaction(status=PENDING)
activate DB
DB --> TO : transactionId
deactivate DB

TO -> GC : authorizeAndCapture(amount)
activate GC
note right: NFR-5.1: Process < 5s 
GC --> TO : PaymentSuccess (provider_id)
deactivate GC

TO -> ES : grantCourseAccess(userId, courseId)
activate ES
note right: NFR-R1: Atomic enrollment 
ES --> TO : AccessGranted
deactivate ES

TO -> DB : updateStatus(SUCCESS, provider_id)
TO -> SL : logActivity(maskedData)
note right: NFR-S4: Hide sensitive data 

TO --> PC : Result: SUCCESS
deactivate TO

PC --> User : 201 Created (Access Granted)
note left: FR-5.2: Immediate access 
@enduml