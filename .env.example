# Database Credentials
DB_USER=payment_user
DB_PASSWORD=secure_password
DB_NAME=payment_service

# Connection URLs
# Using asyncpg for async SQLAlchemy support
DATABASE_URL=postgresql+asyncpg://payment_user:secure_password@payment-db:5432/payment_service
REDIS_URL=redis://payment-redis:6379/0

# App Settings
API_TIMEOUT=5
